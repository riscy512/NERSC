#!/usr/bin/env python3
"""
Backward-compatible wrapper: parses -H -o -g and calls omniaHosts module.
Prefer: omniactl hosts, omniactl genders.
"""

import sys
from pathlib import Path

# Add script dir for imports
SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))

def main():
    from omniaHosts import load_cluster, write_hosts, write_genders, IPReuseError

    csv_path = SCRIPT_DIR / "ips.csv"
    getOpts = {"hosts": False, "hosts_path": None, "genders": False, "genders_path": None}
    argv = sys.argv[1:]
    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg == "-H":
            getOpts["hosts"] = True
        elif arg == "-o":
            getOpts["hosts"] = True
            if i + 1 < len(argv) and not argv[i + 1].startswith("-"):
                getOpts["hosts_path"] = Path(argv[i + 1])
                i += 1
            else:
                getOpts["hosts_path"] = SCRIPT_DIR / "hosts"
        elif arg == "-g":
            getOpts["genders"] = True
            if i + 1 < len(argv) and not argv[i + 1].startswith("-"):
                getOpts["genders_path"] = Path(argv[i + 1])
                i += 1
            else:
                getOpts["genders_path"] = SCRIPT_DIR / "genders"
        i += 1

    try:
        cluster, ip_to_data = load_cluster(csv_path)
    except FileNotFoundError as e:
        print(f"{e}", file=sys.stderr)
        sys.exit(1)
    except ValueError as e:
        print(f"{e}", file=sys.stderr)
        sys.exit(1)
    except IPReuseError as e:
        print("WARNING: IP address re-use detected (same IP, different host/interface).", file=sys.stderr)
        for err in e.errors:
            print(f"  Conflicting IP: {err['ip']}", file=sys.stderr)
            print(f"    first: {err['first_host']} ({err['first_network']})  names: {', '.join(err['first_names'])}", file=sys.stderr)
            print(f"    also:  {err['also_host']} ({err['also_network']})  names: {', '.join(err['also_names'])}", file=sys.stderr)
        print(f"Total: {len(e.errors)} re-use(s).", file=sys.stderr)
        sys.exit(5)

    if getOpts["hosts"]:
        out = write_hosts(cluster, ip_to_data, path=getOpts["hosts_path"])
        if getOpts["hosts_path"] is not None:
            print(f"Wrote {len(ip_to_data)} entries to {getOpts['hosts_path']}", file=sys.stderr)
        else:
            print(out, end="")

    if getOpts["genders"]:
        gpath = getOpts["genders_path"] if getOpts["genders_path"] is not None else SCRIPT_DIR / "genders"
        write_genders(cluster, filepath=gpath)
        n = len(cluster.get("hosts", {}).get("byNode", {}))
        print(f"Wrote genders ({n} nodes) to {gpath}", file=sys.stderr)


if __name__ == "__main__":
    main()
